@{ Layout = null; }
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - SENA Projects</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { display: flex; align-items: center; justify-content: center; background: radial-gradient(circle at 50% 0%, #1e1b4b 0%, #0b0d1a 60%); }
        .auth-card { width: 100%; max-width: 400px; padding: 40px; }
        .logo-box { margin: 0 auto 24px; }
        .text-center { text-align: center; }
        .error-msg { color: var(--danger); font-size: 13px; font-weight: 600; margin-bottom: 20px; background: rgba(248,113,113,0.1); padding: 10px; border-radius: 8px; border: 1px solid rgba(248,113,113,0.2); }
    </style>
</head>
<body>
    <div class="premium-card auth-card">
        <div class="logo-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
        </div>
        <h2 class="page-title text-center" style="font-size: 24px;">SENA Projects</h2>
        <p class="page-subtitle text-center">Inicia sesión para continuar</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="error-msg">
                @Html.ValidationSummary(false, "", new { @class = "text-danger" })
            </div>
        }

        <form action="/Auth/Login?returnUrl=@(ViewData["ReturnUrl"])" method="post">
            <div class="input-group">
                <label>Correo Electrónico</label>
                <input type="email" name="email" required placeholder="admin@example.com" />
            </div>
            <div class="input-group">
                <label>Contraseña</label>
                <input type="password" name="password" required placeholder="••••••••" />
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%; height: 44px; margin-top: 10px;">Ingresar</button>
        </form>

        <p class="text-center" style="margin-top: 24px; font-size: 13px; color: var(--text-secondary);">
            ¿No tienes cuenta? <a href="/Auth/Register" style="color: var(--accent-color); font-weight: 700; text-decoration: none;">Regístrate</a>
        </p>
    </div>
</body>
</html>
